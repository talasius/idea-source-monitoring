      <CodeComponent name="skipConfidenceRoutine" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((rememberedIdeas.length === 0)) {&amp;#10;    continueRoutine = false;&amp;#10;} else {&amp;#10;    currentСonfIdea = rememberedIdeas[confidence_loop.thisN];&amp;#10;    confidenceIdeaText.text = `«${currentСonfIdea}»`;&amp;#10;    confidenceSlider.reset();&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if len(rememberedIdeas) == 0:&amp;#10;    continueRoutine = False&amp;#10;else:&amp;#10;    currentСonfIdea = rememberedIdeas[confidence_loop.thisN]&amp;#10;    confidenceIdeaText.text = (f'«{currentСonfIdea}»')&amp;#10;    confidenceSlider.reset()" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="score = confidenceSlider.getRating();&amp;#10;if ((score === null)) {&amp;#10;    score = (- 1);&amp;#10;}&amp;#10;confidenceScores[currentСonfIdea] = score;&amp;#10;psychoJS.experiment.addData(&quot;conf_idea&quot;, currentСonfIdea);&amp;#10;psychoJS.experiment.addData(&quot;conf_score&quot;, score);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="score = confidenceSlider.getRating()&amp;#10;if score is None:&amp;#10;    score = -1&amp;#10;&amp;#10;confidenceScores[currentСonfIdea] = score&amp;#10;&amp;#10;thisExp.addData('conf_idea', currentСonfIdea)&amp;#10;thisExp.addData('conf_score', score)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="skipConfidenceRoutine" valType="code" updates="None" name="name"/>
