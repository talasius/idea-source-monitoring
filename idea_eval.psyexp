        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="sourceText = sourceEvaluationTextBox.getText();&amp;#10;sourceText = (sourceText ? sourceText.strip() : &quot;&quot;);&amp;#10;psychoJS.experiment.addData(&quot;source_description&quot;, sourceText);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="sourceText = sourceEvaluationTextBox.getText()&amp;#10;&amp;#10;sourceText = sourceText.strip() if sourceText else ''&amp;#10;&amp;#10;thisExp.addData('source_description', sourceText)" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="formatSourceText" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
