        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if (((rInstructionCount &gt;= 1) &amp;&amp; (currentRole !== &quot;observation&quot;))) {&amp;#10;    continueRoutine = false;&amp;#10;} else {&amp;#10;    rInstructionCount += 1;&amp;#10;}&amp;#10;if ((currentRole === &quot;observation&quot;)) {&amp;#10;    instructionFirstPartObserverText.opacity = 1.0;&amp;#10;    instructionFirstPartText.opacity = 0;&amp;#10;} else {&amp;#10;    instructionFirstPartObserverText.opacity = 0;&amp;#10;    instructionFirstPartText.opacity = 1.0;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if rInstructionCount &gt;= 1 and currentRole != 'observation':&amp;#10;    continueRoutine = False&amp;#10;else: &amp;#10;    rInstructionCount += 1&amp;#10;&amp;#10;if currentRole == 'observation':&amp;#10;    instructionFirstPartObserverText.opacity = 1.0&amp;#10;    instructionFirstPartText.opacity = 0&amp;#10;else: &amp;#10;    instructionFirstPartObserverText.opacity = 0&amp;#10;    instructionFirstPartText.opacity = 1.0" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
